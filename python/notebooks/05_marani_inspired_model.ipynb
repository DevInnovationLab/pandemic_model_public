     ]
    }
   ],
   "source": [
    "## Fit generalized Pareto distribution on extreme epidemics\n",
    "params_marani_inspired = genpareto.fit(df_marani_inspired_exceed['severity_smu'], floc=thresh)\n",
    "\n",
    "## Print results\n",
    "print(params_marani_inspired)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "metadata": {},
   "outputs": [],
   "source": [
    "## Find arrival rate of threshold-exceeding epidemics during 2000 to 2019\n",
    "arrival_severe_marani_inspired = df_marani_inspired_exceed[(df_marani_inspired_exceed['year_start'] >= 2000) & \n",
    "                                                           (df_marani_inspired_exceed['year_start'] <= 2019)\n",
    "                                                          ].shape[0] / 20\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "0.1\n"
     ]
    }
   ],
   "source": [
    "## Print arrival rate of threshold-exceeding events\n",
    "print(round(arrival_severe_marani_inspired, 3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "metadata": {},
   "outputs": [],
   "source": [
    "## Calculate exceedance probabilities\n",
    "exceedance = arrival_severe_marani_inspired * (1 - genpareto.cdf(severity, \n",
    "                                                                 *params_marani_inspired))\n",
    "\n",
    "df_marani_inspired = pd.DataFrame({\n",
    "    \"severity\": severity,\n",
    "    \"exceedance\": exceedance\n",
    "})\n",
    "\n",
    "## Sort and reset index (optional)\n",
    "df_marani_inspired = df_marani_inspired.sort_values(by='severity', ascending=True)\n",
    "df_marani_inspired = df_marani_inspired.reset_index(drop=True)"
   ]
  },
