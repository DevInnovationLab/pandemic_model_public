  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "(np.float64(3.10566988378568), 0.01, np.float64(0.6836398044667586))\n"
     ]
    }
   ],
   "source": [
    "## Fit generalized Pareto distribution on extreme epidemics\n",
    "params_marani_star = genpareto.fit(df_marani_star_exceed['severity_smu'], floc=thresh)\n",
    "\n",
    "## Print results\n",
    "print(params_marani_star)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [],
   "source": [
    "## Find arrival rate of all epidemics during 2000 to 2019\n",
    "arrival_all = df_resp_viral[(df_resp_viral['year_start'] >= 2000) & \n",
    "                            (df_resp_viral['year_start'] <= 2019)].shape[0] / 20\n",
    "\n",
    "## Find probability of epidemic exceeding the threshold conditional on arrival\n",
    "exceed_prob = df_marani_star_exceed.shape[0] / df_marani_star.shape[0]\n",
    "\n",
    "## Find arrival rate of threshold-exceeding resp viral epidemics\n",
    "arrival_severe_marani_star = arrival_all * exceed_prob"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "0.033\n"
     ]
    }
   ],
   "source": [
    "## Print arrival rate of threshold-exceeding events\n",
    "print(round(arrival_severe_marani_star, 3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
   "outputs": [],
   "source": [
    "## Calculate exceedance probabilities\n",
    "exceedance = arrival_severe_marani_star * (1 - genpareto.cdf(severity, \n",
    "                                                             *params_marani_star))\n",
    "\n",
    "df_marani_star = pd.DataFrame({\n",
    "    \"severity\": severity,\n",
    "    \"exceedance\": exceedance\n",
    "})\n",
    "\n",
    "## Sort and reset index (optional)\n",
    "df_marani_star = df_marani_star.sort_values(by='severity', ascending=True)\n",
    "df_marani_star = df_marani_star.reset_index(drop=True)\n"
   ]
  },
